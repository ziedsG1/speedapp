# Local dev only — never commit this file with real keys
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
SERPAPI_API_KEY=YOUR_SERPAPI_API_KEY

# Routing priority (automatic):
# 1. SerpApi — if SERPAPI_API_KEY is set (google_maps_directions engine)
# 2. OSRM — FREE, no key, real street paths (OpenStreetMap)
# 3. Google Directions — if GOOGLE_MAPS_API_KEY is set (optional fallback)

# Google Maps key is still used for the map tiles on Android.
# Directions API is NOT required anymore — OSRM works without any key.
